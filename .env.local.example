# Copy to .env.local and fill with your Supabase project values
# (Project Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Optional but recommended: protects the daily cron endpoint.
# Set the same value in Vercel project env vars.
CRON_SECRET=make-a-long-random-string

# Optional: protects the /api/cron/generate endpoint. Set the same value in
# Vercel project settings; Vercel Cron sends it automatically as a Bearer token.
CRON_SECRET=any-long-random-string

# --- Email (optional; invites & daily digest work once these are set) ---
# Resend API key from https://resend.com (Settings -> API Keys)
RESEND_API_KEY=
# Verified sender. For testing you can use Resend's onboarding@resend.dev,
# which only delivers to your own Resend account email.
RESEND_FROM=Sitewatch <onboarding@resend.dev>
# Your deployed app URL, used for links in emails (no trailing slash)
APP_URL=https://your-app.vercel.app
# Service role key (Supabase -> Settings -> API). SERVER ONLY — never expose.
SUPABASE_SERVICE_ROLE_KEY=
